NODE_ENV=production
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=true
ENABLE_FRONTEND_DIST=true

# Generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=24h

DATA_DIR=/var/lib/tsukuyomi-space
DB_PATH=/var/lib/tsukuyomi-space/tsukuyomi.db
CORS_ORIGINS=https://your-domain.example

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@your-domain.example
ADMIN_PASSWORD=change-this-admin-password

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=月读空间

LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=moonshot-v1-8k

TTS_PROVIDER=mimo
TTS_API_KEY=
TTS_API_URL=
TTS_MODEL=mimo-v2-tts
TTS_VOICE=mimo_default
