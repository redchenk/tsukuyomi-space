NODE_ENV=production
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=true
ENABLE_FRONTEND_DIST=true

# Generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=24h

# Leave empty to use the in-process fallback store.
# If you add a Redis service, set this to redis://redis:6379/0.
REDIS_URL=
REDIS_TIMEOUT_MS=1200
EMAIL_CODE_TTL_MS=600000
EMAIL_CODE_COOLDOWN_MS=60000
LOGIN_FAILURE_WINDOW_SECONDS=900
LOGIN_FAILURE_MAX=8
WEATHER_CACHE_SECONDS=600

DATA_DIR=/data
DB_PATH=/data/tsukuyomi.db
CORS_ORIGINS=http://localhost:3280

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=月读空间

LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=moonshot-v1-8k

TTS_PROVIDER=mimo
TTS_API_KEY=
TTS_API_URL=
TTS_MODEL=mimo-v2-tts
TTS_VOICE=mimo_default
